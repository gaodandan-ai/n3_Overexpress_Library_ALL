# =========================================================================
# Growth Profiler 数据处理项目 Git 忽略规范 (.gitignore)
# =========================================================================

# -------------------------------------------------------------------------
# 1. 建议排除的数据文件夹 (防止巨大的 Excel 二进制文件和图片撑爆 GitHub 仓库)
# -------------------------------------------------------------------------
01_raw_picture/         # 原始图片以及 ezproj 工程文件夹
02_raw_data_od/         # 原始 OD 数据文件
03_raw_data_r/          # 原始 R 数据文件
04_result/              # 所有合并、计算输出的中间体和最终 excel 结果
00_script/swap_*.py     # 纠错与临时性数据处理脚本

# -------------------------------------------------------------------------
# 2. 微软 Excel 临时锁文件 (必忽略，防止打开 Excel 时的临时缓冲文件被提交)
# -------------------------------------------------------------------------
~$*.xlsx
~$*.xls
~$*.csv

# -------------------------------------------------------------------------
# 3. Python 运行时和缓存文件
# -------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo
.pytest_cache/
.ipynb_checkpoints/

# Python 虚拟环境 (如果您在本地使用了虚拟环境)
.venv/
venv/
ENV/
env/

# -------------------------------------------------------------------------
# 4. 个人编辑器和 IDE 配置文件
# -------------------------------------------------------------------------
.vscode/                # VS Code 个人工作区配置
.idea/                  # PyCharm 个人配置项目
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.history/               # Local History 插件缓存

# -------------------------------------------------------------------------
# 5. 系统级垃圾文件
# -------------------------------------------------------------------------
Thumbs.db
desktop.ini
.DS_Store
